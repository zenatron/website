---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header";
import Footer from "@/components/Footer";
import BackToTopButton from "@/components/ui/BackToTopButton";
import KatexStyles from "@/components/KatexStyles";
import GitHubReadme from "@/components/ui/GitHubReadme";
import ProjectDownloads from "@/components/ui/ProjectDownloads";
import HtmlRenderer from "@/components/HtmlRenderer";
import dateFormatter from "@/utils/dateFormatter";
import { getGithubRepos } from "@/lib/github";
import Counter from "@/components/mdx/Counter";
import Callout from "@/components/mdx/Callout";
import NotebookEmbed from "@/components/mdx/NotebookEmbed";
import fs from "node:fs";
import path from "node:path";

export async function getStaticPaths() {
  const entries = await getCollection("projects");
  const mdxPaths = entries.map((entry) => ({
    params: { slug: entry.data.slug || entry.slug },
    props: { type: "mdx" as const, entry },
  }));

  const githubProjects = await getGithubRepos();
  const githubPaths = githubProjects.map((project) => ({
    params: { slug: project.metadata.slug },
    props: { type: "github" as const, project },
  }));

  return [...mdxPaths, ...githubPaths];
}

const props = Astro.props;
let metadata: any;
let Content: any = null;
let htmlContent = "";
let links: any = {};
let downloads: any[] = [];

if (props.type === "mdx") {
  const entry = props.entry;
  const rendered = await entry.render();
  Content = rendered.Content;
  metadata = {
    title: entry.data.title || entry.slug,
    description: entry.data.description || "",
    type: entry.data.type || "other",
    slug: entry.data.slug || entry.slug,
    date: entry.data.date,
    tags: entry.data.tags || [],
    image: entry.data.image,
    images: entry.data.images,
    video: entry.data.video,
    videos: entry.data.videos,
    featured: entry.data.featured || false,
    contentSource: entry.data.contentSource || "mdx",
    notebookHtml: entry.data.notebookHtml,
    githubRepo: entry.data.githubRepo,
  };
  links = {
    github: entry.data.github,
    live: entry.data.live || entry.data.demoUrl,
  };
  downloads = entry.data.downloads || [];

  if (entry.data.notebookHtml) {
    const filename = entry.data.notebookHtml.endsWith(".html")
      ? entry.data.notebookHtml
      : `${entry.data.notebookHtml}.html`;
    const htmlPath = path.join(process.cwd(), "public/downloads", filename);
    if (fs.existsSync(htmlPath)) {
      htmlContent = fs.readFileSync(htmlPath, "utf8");
    }
  }
} else {
  const project = props.project;
  metadata = project.metadata;
  links = project.links;
}

if (!metadata) {
  return Astro.redirect("/projects");
}
---

<BaseLayout title={`${metadata.title} | Phil Vishnevsky`}>
  <div class="relative flex min-h-screen flex-col">
    <KatexStyles client:load />
    <Header client:load />
    <main class="flex-1 px-4 py-10 pt-20 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <!-- Header Navigation -->
        <div class="flex justify-between items-center mb-6">
          <a
            href="/projects"
            class="inline-flex items-center btn-nav text-sm md:text-base"
            title="Back to Projects"
          >
            ← Back to Projects
          </a>

          <div class="flex gap-2 md:gap-4">
            {links?.github && (
              <a
                href={links.github}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-white/5 backdrop-blur-md border border-white/10 rounded-lg px-2 md:px-4 py-1.5 text-xs md:text-sm inline-flex items-center gap-2 hover:bg-white/10 hover:border-white/20 shadow-lg transition-all duration-300"
                title="View on GitHub"
              >
                GitHub
              </a>
            )}
            {links?.live && (
              <a
                href={links.live}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-white/5 backdrop-blur-md border border-white/10 rounded-lg px-2 md:px-4 py-1.5 text-xs md:text-sm inline-flex items-center gap-2 hover:bg-white/10 hover:border-white/20 shadow-lg transition-all duration-300"
                title="View Live Demo"
              >
                Live Demo
              </a>
            )}
            {downloads && downloads.length > 0 && (
              <ProjectDownloads
                downloads={downloads}
                projectTitle={metadata.title}
                client:load
              />
            )}
          </div>
        </div>

        <!-- Project Header -->
        <div class="mb-8 text-center">
          <h1 class="text-4xl md:text-5xl font-bold mb-4">{metadata.title}</h1>
          {metadata.date && (
            <p class="text-muted-text mb-2">
              {dateFormatter({ date: metadata.date, formatStyle: "long" })}
            </p>
          )}
          <p class="text-lg text-muted-text mb-4 max-w-3xl mx-auto">{metadata.description}</p>
          {metadata.tags && metadata.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 justify-center">
              {metadata.tags.map((tag: string) => (
                <a
                  href={`/projects?tag=${encodeURIComponent(tag)}`}
                  class="tag-bubble text-sm"
                  title={`View projects with tag: ${tag}`}
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </div>

        <!-- Featured Image -->
        {metadata.image && (
          <div class="mb-8 rounded-lg overflow-hidden shadow-lg">
            <img src={metadata.image} alt={metadata.title} class="w-full h-auto" />
          </div>
        )}

        <!-- Featured Video -->
        {metadata.video && (
          <div class="mb-8 rounded-lg overflow-hidden shadow-lg aspect-video">
            {metadata.video.includes("youtube.com") || metadata.video.includes("youtu.be") ? (
              <iframe
                src={metadata.video.replace("watch?v=", "embed/")}
                title={metadata.title}
                class="w-full h-full"
                allowfullscreen
              ></iframe>
            ) : (
              <video src={metadata.video} controls class="w-full h-full">
                Your browser does not support the video tag.
              </video>
            )}
          </div>
        )}

        <!-- MDX Content -->
        {(metadata.contentSource === "mdx" || metadata.contentSource === "notebook") && Content && (
          <div class="mdx-content w-full max-w-3xl mx-auto mb-8">
            <Content components={{ Counter, Callout, NotebookEmbed }} />
          </div>
        )}

        <!-- GitHub README for enhanced projects -->
        {metadata.contentSource === "mdx" && metadata.githubRepo && (
          <div class="mt-8 w-full">
            <h2 class="text-3xl font-bold mb-4">Repository README</h2>
            <GitHubReadme repo={metadata.githubRepo} client:load />
          </div>
        )}

        <!-- GitHub README Only -->
        {metadata.contentSource === "github" && metadata.githubRepo && (
          <div class="w-full">
            <GitHubReadme repo={metadata.githubRepo} client:load />
          </div>
        )}

        <!-- Raw HTML -->
        {metadata.contentSource === "html" && htmlContent && (
          <div class="bg-white rounded-lg shadow-lg overflow-hidden">
            <HtmlRenderer htmlContent={htmlContent} title={metadata.title} client:load />
          </div>
        )}

        <!-- Image Gallery -->
        {metadata.images && metadata.images.length > 0 && (
          <div class="mt-8">
            <h2 class="text-2xl font-bold mb-4">Gallery</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {metadata.images.map((image: string, index: number) => (
                <div class="rounded-lg overflow-hidden shadow-lg">
                  <img src={image} alt={`${metadata.title} - Image ${index + 1}`} class="w-full h-auto" />
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Video Gallery -->
        {metadata.videos && metadata.videos.length > 0 && (
          <div class="mt-8">
            <h2 class="text-2xl font-bold mb-4">Videos</h2>
            <div class="grid grid-cols-1 gap-4">
              {metadata.videos.map((video: string, index: number) => (
                <div class="rounded-lg overflow-hidden shadow-lg aspect-video">
                  {video.includes("youtube.com") || video.includes("youtu.be") ? (
                    <iframe
                      src={video.replace("watch?v=", "embed/")}
                      title={`${metadata.title} - Video ${index + 1}`}
                      class="w-full h-full"
                      allowfullscreen
                    ></iframe>
                  ) : (
                    <video src={video} controls class="w-full h-full">
                      Your browser does not support the video tag.
                    </video>
                  )}
                </div>
              ))}
            </div>
          </div>
        )}
      </div>
    </main>
    <Footer client:load />
    <BackToTopButton client:load />
  </div>
</BaseLayout>
